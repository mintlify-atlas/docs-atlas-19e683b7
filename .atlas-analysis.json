{
  "projectType": "general",
  "projectName": "Cart Management System",
  "projectDescription": "A C# console application for managing a shopping cart with product browsing, item management, discount vouchers, and checkout across multiple storage backends.",
  "theme": "almond",
  "primaryColor": "#3B82F6",
  "lightColor": "#EFF6FF",
  "darkColor": "#1E3A5F",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "architecture"]
          },
          {
            "group": "Features",
            "pages": ["features/cart-management", "features/products", "features/vouchers", "features/checkout"]
          },
          {
            "group": "Storage Backends",
            "pages": ["storage/overview", "storage/in-memory", "storage/json-file", "storage/database"]
